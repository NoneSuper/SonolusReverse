{
  "name": "sonolusreverse",
  "description": "Mod for Sonolus written using frida and frida-il2cpp-bridge",
  "version": "1.0.0",
  "author": "https://github.com/repinek",
  "keywords": [
    "frida",
    "il2cpp",
    "unity",
    "sonolus",
    "mod"
  ],
  "license": "GPL-3.0",
  "homepage": "https://github.com/repinek/SonolusReverse#readme",
  "repository": "github:repinek/SonolusReverse",
  "bugs": {
    "url": "https://github.com/repinek/SonolusReverse/issues"
  },
  "scripts": {
    "prepare": "husky",
    "build": "npm run build:release",
    "build:dev": "npm run prettier && webpack --env dev",
    "build:release": "npm run prettier && webpack --env release",
    "build:nobump": "npm run prettier && webpack --env release --env noBump",
    "spawn": "frida -U Gadget -l dist/agent.js",
    "spawn:dev": "npm run build:dev && npm run spawn",
    "spawn:release": "npm run build && npm run spawn",
    "prettier": "prettier --ignore-path .gitignore --ignore-path .prettierignore --write  \"**/*.{ts,mts,json,md}\"",
    "lint": "eslint . --fix"
  },
  "lint-staged": {
    "**/*.{ts,mts,json,md}": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@eslint/config-helpers": "^0.6.0",
    "@eslint/js": "^10.0.1",
    "@types/frida-gum": "^19.1.0",
    "@types/node": "^25.7.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "ifdef-loader": "^2.3.2",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "terser-webpack-plugin": "^5.6.0",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "frida-il2cpp-bridge": "^0.13.1"
  },
  "prettier": {
    "tabWidth": 4,
    "arrowParens": "avoid",
    "trailingComma": "none",
    "printWidth": 160
  }
}
