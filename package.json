{
  "name": "sonolusreverse",
  "description": "Mod for Sonolus written using frida and frida-il2cpp-bridge",
  "version": "1.0.0",
  "author": "https://github.com/repinek",
  "keywords": [
    "frida",
    "il2cpp",
    "unity",
    "sonolus",
    "mod"
  ],
  "license": "GPL-3.0",
  "homepage": "https://github.com/repinek/SonolusReverse#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/repinek/SonolusReverse.git"
  },
  "bugs": {
    "url": "https://github.com/repinek/SonolusReverse/issues"
  },
  "main": "src/index.ts",
  "scripts": {
    "build": "frida-compile src/index.ts -o dist/agent.js",
    "spawn": "frida -U Gadget -l dist/agent.js",
    "prettier": "prettier --ignore-path .gitignore --write --ignore-path .prettierignore \"**/*.{ts,mts,json,md}\"",
    "lint": "eslint .",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,mts,json,md}": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@eslint/config-helpers": "^0.6.0",
    "@eslint/js": "^10.0.1",
    "@types/frida-gum": "^19.0.2",
    "@types/node": "^25.6.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "frida-compile": "^19.0.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.3",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "frida-il2cpp-bridge": "^0.13.1"
  },
  "prettier": {
    "tabWidth": 4,
    "arrowParens": "avoid",
    "trailingComma": "none",
    "printWidth": 160
  }
}
