{
    "compilerOptions": {
        "target": "esnext",
        "lib": ["ESNext", "DOM"],
        "module": "NodeNext",
        "moduleResolution": "nodenext",
        "types": ["node", "frida-gum"],
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "noImplicitOverride": true,
        "useUnknownInCatchVariables": true
    },
    "include": ["src/**/*", "webpack.config.mts", "eslint.config.mts"]
}
